CREATE TABLE QuoteOfTheDay (
    qotdDate TEXT NOT NULL PRIMARY KEY,
    id INTEGER NOT NULL,
    body TEXT NOT NULL,
    author TEXT NOT NULL,
    favoritesCount INTEGER NOT NULL DEFAULT 0
);

selectForDate:
SELECT * FROM QuoteOfTheDay WHERE qotdDate = :date LIMIT 1;

upsert:
INSERT OR REPLACE INTO QuoteOfTheDay(qotdDate, id, body, author, favoritesCount)
VALUES (?, ?, ?, ?, ?);

deleteOlderThan:
DELETE FROM QuoteOfTheDay WHERE qotdDate != :date;
